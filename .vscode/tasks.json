{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "kill-old-process",
            "command": "taskkill",
            "type": "shell",
            "args": ["/f", "/im", "new try world.exe", "2>nul"],
            "presentation": { "echo": false, "reveal": "never" },
            "problemMatcher": []
        },
        {
            "label": "build",
            "command": "dotnet",
            "type": "process",
            "args": [
                "build",
                "${workspaceFolder}/new try world.sln",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary;ForceNoAlign"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "publish",
            "command": "dotnet",
            "type": "process",
            "args": [
                "publish",
                "${workspaceFolder}/new try world.sln",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary;ForceNoAlign"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "watch",
            "command": "dotnet",
            "type": "process",
            "args": [
                "watch",
                "run",
                "--project",
                "${workspaceFolder}/new try world.sln"
            ],
            "problemMatcher": "$msCompile"
        }
    ]
}